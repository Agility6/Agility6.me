---
import { themeConfig } from '@/config'
import { ClientRouter } from 'astro:transitions'
import ThemeManager from '@/components/ui/ThemeManager.astro'
import TransitionWrapper from '@/components/layout/TransitionWrapper.astro'
import type { LayoutProps } from '@/types'

type Props = LayoutProps

const { type = 'page' } = Astro.props
const language = themeConfig.site.language || 'en-US'
const requestedWidth = Astro.props.width || themeConfig.general.contentWidth
const centeredLayout = Astro.props.centered ?? themeConfig.general.centeredLayout
const fadeAnimation = themeConfig.general.fadeAnimation
const widthValue = Math.min(parseFloat(requestedWidth), 50)
const shouldUseCustomWidth = widthValue > 25
const finalWidth = shouldUseCustomWidth ? `${widthValue}rem` : '25rem'
---

<html lang={language}>
  <head>
    <ThemeManager />
    {fadeAnimation && <ClientRouter />}
    <slot name="head" />
  </head>
  <body
    data-layout-type={type}
    data-centered={centeredLayout}
    style={`
      max-width: ${finalWidth};
      ${shouldUseCustomWidth ? `--content-width: ${widthValue}rem;` : ''}
    `}
  >
    {
      fadeAnimation ? (
        <TransitionWrapper type={type} class="layout-wrapper">
          <slot />
        </TransitionWrapper>
      ) : (
        <div class="layout-wrapper">
          <slot />
        </div>
      )
    }

    <script is:inline define:vars={{ fadeAnimation }}>
      if (!fadeAnimation) {
        const dispatchPageLoad = () => {
          document.dispatchEvent(new Event('astro:page-load'))
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', dispatchPageLoad, { once: true })
        } else {
          queueMicrotask(dispatchPageLoad)
        }
      }
    </script>
  </body>
</html>

<style is:global>
  .layout-wrapper {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }
</style>
